generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin ────────────────────────────────────────

model Admin {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  createdAt      DateTime @default(now())
}

// ─── Portfolio ────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String   @db.Text
  imageUrl    String?
  tags        String[]
  clientName  String?
  projectUrl  String?
  published   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Blog ─────────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String    @db.Text
  imageUrl    String?
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Ressources (PDFs, guides) ────────────────────

model Resource {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  description String
  fileUrl     String
  fileSize    Int
  type        ResourceType
  published   Boolean      @default(false)
  downloads   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ResourceType {
  PDF
  GUIDE
  TEMPLATE
  CHECKLIST
}

// ─── Leads ────────────────────────────────────────

model Lead {
  id         String     @id @default(cuid())
  email      String
  name       String?
  source     LeadSource
  message    String?    @db.Text
  resourceId String?
  createdAt  DateTime   @default(now())

  @@index([email])
  @@index([source])
}

enum LeadSource {
  CONTACT_FORM
  LEAD_MAGNET
  NEWSLETTER
}
